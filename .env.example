# ─────────────────────────────────────────────────────────────────────────
# Secrets for the guided deploy (`npm run setup`). Copy to `.env` and fill in.
# `.env` is gitignored — never commit real seeds.
# ─────────────────────────────────────────────────────────────────────────

# Deployer mnemonic (12/24-word sr25519 seed). Deploys the contracts; its
# account must be funded with the network's native token.
DEPLOYER_SEED="your twelve word mnemonic goes here ..."

# Publisher mnemonic for the DotNS publish (owns the DotNS domains). Optional —
# if unset, the deployer seed is reused for publishing too.
# DOTNS_MNEMONIC="your publisher mnemonic ..."

# ── Custom network only (network=custom in deploy.config.json) ──
# Define your own chain. Genesis hashes are optional (deploy connects via WS).
# CUSTOM_MAIN_WS=wss://your-asset-hub/rpc
# CUSTOM_MAIN_GENESIS=0x...
# CUSTOM_BULLETIN_WS=wss://your-bulletin/rpc
# CUSTOM_BULLETIN_GENESIS=0x...
# CUSTOM_IPFS_GATEWAY=https://your-ipfs-gateway
# CUSTOM_NATIVE_SYMBOL=UNIT
# CUSTOM_NATIVE_DECIMALS=12
# CUSTOM_DISPLAY_NAME=My Network
