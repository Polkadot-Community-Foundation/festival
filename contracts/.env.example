# Active chain network for the deploy scripts (scripts/deploy-festival.ts,
# scripts/deploy-multicall.ts). Empty/unset = paseo (default).
# Valid values: paseo | previewnet. See packages/shared/host/networks.ts.
NETWORK=paseo

# EVM RPC URL — used by foundry / forge for EVM-side tooling.
# Paseo:      https://eth-rpc-testnet.polkadot.io/
# Previewnet: https://previewnet.substrate.dev/eth-rpc
# Get testnet tokens from https://faucet.polkadot.io/
RPC_URL=https://eth-rpc-testnet.polkadot.io/
PRIVATE_KEY=0xYourPrivateKeyHere
DEPLOYER_SEED=your mnemonic seed phrase here
