# PCF public products devnet — standard Paseo Asset Hub (para 1000, EVM chainId 420420417).
#
# Contracts freshly deployed here via `forge script script/Deploy.s.sol:DeployFestival`
# (+ `forge create` for Multicall3 and the orphan FestivalSession) against the revive
# eth-rpc adapter. Every address below verified on-chain (eth_getCode non-empty); the
# Festival is wired as authorized minter on the festival POAP and holds the session POAP
# factory role. Deployer = 0x8C78b53f2CEAF395fDA66152d7A5e6e7A79DB675.
#
# Devnet endpoints (source of truth for the contract/config leg):
#   Asset Hub RPC : wss://asset-hub-paseo-rpc.n.dwellir.com
#   AH genesis    : 0xd6eec26135305a8ad257a20d003357284c8aa03d0bdb2b357ab0a22371e11ef2
#   Bulletin/IPFS : https://bullet.sik.rocks
#
# NOTE (frontend leg, not done here): packages/shared/host/networks.ts has NO `devnet`
# NetworkKey yet — resolveNetwork() throws on unknown keys, and wsUrl/ipfsGateway are NOT
# env-overridable (only genesis hashes are, via VITE_CHAIN_GENESIS_HASH /
# VITE_BULLETIN_GENESIS_HASH). Before the SPAs can build+deploy against devnet, add a
# first-class `devnet` entry (mainChain.wsUrl = the dwellir AH RPC above,
# bulletinChain + ipfsGateway = https://bullet.sik.rocks, mainChain.genesisHash below).
# This file is the deployed-contract + network truth for the retarget.
VITE_NETWORK=devnet
VITE_CHAIN_GENESIS_HASH=0xd6eec26135305a8ad257a20d003357284c8aa03d0bdb2b357ab0a22371e11ef2
VITE_FESTIVAL_ADDRESS=0xAc36c0173eA817c63dFEA1eA796BFD4506d586d2
VITE_FESTIVAL_POAP_ADDRESS=0x0234dBE0C2584729BE58434fd69F9B251F92c13e
VITE_SUB_EVENT_POAP_ADDRESS=0xc411EA624e8f8f0ec2a2145f79e88b80e0269289
VITE_MULTICALL_ADDRESS=0x24F2cCe5598c733415D4cb3d23494C7e589d05bA
ADMIN_DOTNS_DOMAIN=web3summit-admin.dot
ATTENDEE_DOTNS_DOMAIN=web3summit.dot
BULLETIN_ENV=devnet
