# Active chain network. Empty/unset = paseo-next-v2 (default).
# Valid values: paseo-next-v2 | previewnet. See packages/shared/host/networks.ts.
# When switching networks, update the contract addresses below to the
# instances deployed on that network.
VITE_NETWORK=paseo-next-v2

# Genesis hashes for unstable networks (previewnet). Paseo Next V2's hashes are
# pinned in the registry — leave these unset for paseo-next-v2. For previewnet,
# run `bun run sync-network` to populate them with current values, or set them
# manually if you have the hashes.
# VITE_CHAIN_GENESIS_HASH=
# VITE_BULLETIN_GENESIS_HASH=

# Contract addresses (deployed per-network — must match VITE_NETWORK above).
VITE_FESTIVAL_ADDRESS=0xc47c785e120b4b13589423406a5d4ec2c68b407b
VITE_FESTIVAL_POAP_ADDRESS=0x1d8c736c0d449d4b0c78262af2268f8e206243d8
VITE_SUB_EVENT_POAP_ADDRESS=0xa97fc2bfc59a58778807ba34e8b57402536a786a
VITE_MULTICALL_ADDRESS=0x2c2fdf374009bc4f2af002c887fd962b63a68d89

# DotNS identifier for the SPA's product account. In host mode this drives
# the per-user product-account derivation; bulletin chain allowances are
# granted to that derived account.
VITE_DOTNS_ID=festival-admin-dev.dot
