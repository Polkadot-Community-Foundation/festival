# Active chain network. Empty/unset = paseo (default).
# Valid values: paseo | previewnet. See packages/shared/host/networks.ts.
# When switching networks, update the contract addresses below to the
# instances deployed on that network.
VITE_NETWORK=paseo

# Genesis hashes for unstable networks (previewnet). Paseo's hashes are
# pinned in the registry — leave these unset for paseo. For previewnet, run
# `bun run sync-network` to populate them with current values, or set them
# manually if you have the hashes.
# VITE_CHAIN_GENESIS_HASH=
# VITE_BULLETIN_GENESIS_HASH=

# Contract addresses (deployed per-network — must match VITE_NETWORK above).
VITE_FESTIVAL_ADDRESS=0xfedbf3f3e4c2482fefcb3ffe99d4bc0595821787
VITE_FESTIVAL_POAP_ADDRESS=0x10e20bf9f18f3c7697c421b7beabb4b9490e9714
VITE_SUB_EVENT_POAP_ADDRESS=0xcca98080c709eed98d72672936a16a29b90b65fb
VITE_MULTICALL_ADDRESS=0xa7ecfeba636c93ed8eb0886a5fe83e16a1e6dfb8

# DotNS identifier for the SPA's product account. In host mode this drives
# the per-user product-account derivation; bulletin chain allowances are
# granted to that derived account.
VITE_DOTNS_ID=festival-attendee-dev.dot
