# Previewnet. Use `npm run dev:attendee:previewnet` / `build:attendee:previewnet`.
# Previewnet is rebuilt frequently from runtimes#master, so genesis hashes
# go stale fast. Run `npm run sync-network -- --network previewnet` and
# paste the resulting VITE_*_GENESIS_HASH lines into `.env.previewnet`
# before booting against this network.
VITE_NETWORK=previewnet

# Genesis hashes are dynamic on previewnet — populate via sync-network.
# VITE_CHAIN_GENESIS_HASH=
# VITE_BULLETIN_GENESIS_HASH=

# Contract addresses on previewnet. Re-run `npm run deploy:previewnet` to
# refresh these — they will be auto-written into `.env.previewnet`
# (this file's gitignored sibling).
VITE_FESTIVAL_ADDRESS=0xdc5d65fa0f921a6d626d3a16cbacc51da21da0c9
VITE_FESTIVAL_POAP_ADDRESS=0x8c70fec191ceef7723b557c9c775d2d08e34cdb9
VITE_SUB_EVENT_POAP_ADDRESS=0xabf02e13c8d2bd3883bea007415bab848c22f1be
VITE_MULTICALL_ADDRESS=0x08f1c9b3be7c7b3ecbc051a78597b40c106e1386

VITE_DOTNS_ID=festival-attendee-previewnet.dot
